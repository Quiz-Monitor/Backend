### QuizMonitor API - Complete Workflow Test
### This file tests the complete exam lifecycle from creation to submission

@baseUrl = https://localhost:7158
@instructorToken = {{loginInstructor.response.body.token}}
@studentToken = {{loginStudent.response.body.token}}
@examId = {{createExam.response.body.examId}}
@examCode = {{createExam.response.body.examCode}}
@attemptId = {{startExam.response.body.attemptId}}
@question1Id = {{addQuestion1.response.body.questionId}}
@question2Id = {{addQuestion2.response.body.questionId}}

###############################################
### PART 1: INSTRUCTOR - CREATE EXAM
###############################################

### 1.1 Register Instructor
POST {{baseUrl}}/api/auth/register
Content-Type: application/json

{
  "email": "instructor@quizmonitor.com",
  "password": "Instructor@123",
  "fullName": "Dr. Sarah Johnson",
  "role": "Instructor",
  "phoneNumber": "01234567890"
}

### 1.2 Login as Instructor
# @name loginInstructor
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "email": "instructor@quizmonitor.com",
  "password": "Instructor@123"
}

### 1.3 Get Instructor Profile
GET {{baseUrl}}/api/users/me
Authorization: Bearer {{instructorToken}}

### 1.4 Create Exam
# @name createExam
POST {{baseUrl}}/api/exams
Content-Type: application/json
Authorization: Bearer {{instructorToken}}

{
  "title": "Data Structures Final Exam",
  "description": "Comprehensive exam covering arrays, linked lists, trees, and graphs",
  "durationMinutes": 90,
  "startTime": "2026-02-11T10:00:00Z",
  "endTime": "2026-02-11T23:59:59Z",
  "cameraRequired": true,
  "tabSwitchingDetection": true,
  "eyeTrackingEnabled": true,
  "multiplePersonDetection": true,
  "maxTabSwitches": 3,
  "maxEyeAwaySeconds": 15
}

### 1.5 Add Question 1 - MCQ Single Choice
# @name addQuestion1
POST {{baseUrl}}/api/exams/{{examId}}/questions
Content-Type: application/json
Authorization: Bearer {{instructorToken}}

{
  "questionType": "mcq_single",
  "questionText": "What is the time complexity of binary search on a sorted array?",
  "points": 10,
  "orderNumber": 1,
  "isRequired": true,
  "choices": [
    { "text": "O(n)", "isCorrect": false, "orderNumber": 1 },
    { "text": "O(log n)", "isCorrect": true, "orderNumber": 2 },
    { "text": "O(n²)", "isCorrect": false, "orderNumber": 3 },
    { "text": "O(1)", "isCorrect": false, "orderNumber": 4 }
  ]
}

### 1.6 Add Question 2 - MCQ Multiple Choice
# @name addQuestion2
POST {{baseUrl}}/api/exams/{{examId}}/questions
Content-Type: application/json
Authorization: Bearer {{instructorToken}}

{
  "questionType": "mcq_multiple",
  "questionText": "Which of the following are linear data structures?",
  "points": 15,
  "orderNumber": 2,
  "isRequired": true,
  "choices": [
    { "text": "Array", "isCorrect": true, "orderNumber": 1 },
    { "text": "Linked List", "isCorrect": true, "orderNumber": 2 },
    { "text": "Binary Tree", "isCorrect": false, "orderNumber": 3 },
    { "text": "Stack", "isCorrect": true, "orderNumber": 4 },
    { "text": "Graph", "isCorrect": false, "orderNumber": 5 }
  ]
}

### 1.7 Add Question 3 - True/False
# @name addQuestion3
POST {{baseUrl}}/api/exams/{{examId}}/questions
Content-Type: application/json
Authorization: Bearer {{instructorToken}}

{
  "questionType": "mcq_single",
  "questionText": "A stack follows FIFO (First In First Out) principle.",
  "points": 5,
  "orderNumber": 3,
  "isRequired": true,
  "choices": [
    { "text": "True", "isCorrect": false, "orderNumber": 1 },
    { "text": "False", "isCorrect": true, "orderNumber": 2 }
  ]
}

### 1.8 Add Question 4 - Short Answer
# @name addQuestion4
POST {{baseUrl}}/api/exams/{{examId}}/questions
Content-Type: application/json
Authorization: Bearer {{instructorToken}}

{
  "questionType": "short_answer",
  "questionText": "Explain the difference between a queue and a stack in your own words.",
  "points": 20,
  "orderNumber": 4,
  "isRequired": true
}

### 1.9 Publish Exam
# @name publishExam
POST {{baseUrl}}/api/exams/{{examId}}/publish
Authorization: Bearer {{instructorToken}}

###############################################
### PART 2: STUDENT - REGISTER & JOIN EXAM
###############################################

### 2.1 Register Student
POST {{baseUrl}}/api/auth/register
Content-Type: application/json

{
  "email": "student@quizmonitor.com",
  "password": "Student@123",
  "fullName": "John Doe",
  "role": "Student",
  "phoneNumber": "01987654321"
}

### 2.2 Login as Student
# @name loginStudent
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "email": "student@quizmonitor.com",
  "password": "Student@123"
}

### 2.3 Get Student Profile
GET {{baseUrl}}/api/users/me
Authorization: Bearer {{studentToken}}

### 2.4 Join Exam by Code
# @name joinExam
POST {{baseUrl}}/api/exams/join
Content-Type: application/json
Authorization: Bearer {{studentToken}}

{
  "examCode": "XMWYT3"
}

###############################################
### PART 3: STUDENT - START & TAKE EXAM
###############################################

### 3.1 Start Exam Attempt
# @name startExam
POST {{baseUrl}}/api/exam-attempts/start
Content-Type: application/json
Authorization: Bearer {{studentToken}}

{
  "examId": 1
}

### 3.2 Get Question 1 (Should return from StartExam response, but testing endpoint)
GET {{baseUrl}}/api/exam-attempts/{{attemptId}}/questions/1
Authorization: Bearer {{studentToken}}

### 3.3 Answer Question 1 (Correct Answer: O(log n))
POST {{baseUrl}}/api/exam-attempts/{{attemptId}}/answers
Content-Type: application/json
Authorization: Bearer {{studentToken}}

{
  "questionId": 1,
  "selectedChoices": [2],
  "startedAt": "2026-02-11T10:05:00Z",
  "answeredAt": "2026-02-11T10:06:30Z",
  "timeSpentSeconds": 90
}

### 3.4 Log Violation - Tab Switch (Student accidentally switched tabs)
POST {{baseUrl}}/api/exam-attempts/{{attemptId}}/violations
Content-Type: application/json
Authorization: Bearer {{studentToken}}

{
  "questionId": 1,
  "violationType": "TAB_SWITCH",
  "description": "Student switched to another browser tab",
  "durationSeconds": 3,
  "screenshotUrl": "https://cdn.example.com/violations/tab_switch_001.png",
  "metadata": {
    "tabCount": 1,
    "timestamp": "2026-02-11T10:06:00Z"
  }
}

### 3.5 Get Question 2
GET {{baseUrl}}/api/exam-attempts/{{attemptId}}/questions/2
Authorization: Bearer {{studentToken}}

### 3.6 Answer Question 2 (Correct Answers: Array, Linked List, Stack)
POST {{baseUrl}}/api/exam-attempts/{{attemptId}}/answers
Content-Type: application/json
Authorization: Bearer {{studentToken}}

{
  "questionId": 2,
  "selectedChoices": [1, 2, 4],
  "startedAt": "2026-02-11T10:07:00Z",
  "answeredAt": "2026-02-11T10:09:45Z",
  "timeSpentSeconds": 165
}

### 3.7 Get Question 3
GET {{baseUrl}}/api/exam-attempts/{{attemptId}}/questions/3
Authorization: Bearer {{studentToken}}

### 3.8 Answer Question 3 (Correct Answer: False - Stack is LIFO)
POST {{baseUrl}}/api/exam-attempts/{{attemptId}}/answers
Content-Type: application/json
Authorization: Bearer {{studentToken}}

{
  "questionId": 3,
  "selectedChoices": [2],
  "startedAt": "2026-02-11T10:10:00Z",
  "answeredAt": "2026-02-11T10:10:30Z",
  "timeSpentSeconds": 30
}

### 3.9 Log Violation - Eye Away
POST {{baseUrl}}/api/exam-attempts/{{attemptId}}/violations
Content-Type: application/json
Authorization: Bearer {{studentToken}}

{
  "questionId": 3,
  "violationType": "EYE_AWAY",
  "description": "Student looked away from screen",
  "durationSeconds": 12,
  "screenshotUrl": "https://cdn.example.com/violations/eye_away_001.png",
  "metadata": {
    "eyeAwayCount": 1,
    "timestamp": "2026-02-11T10:10:15Z"
  }
}

### 3.10 Get Question 4
GET {{baseUrl}}/api/exam-attempts/{{attemptId}}/questions/4
Authorization: Bearer {{studentToken}}

### 3.11 Answer Question 4 (Short Answer - Will need manual grading)
POST {{baseUrl}}/api/exam-attempts/{{attemptId}}/answers
Content-Type: application/json
Authorization: Bearer {{studentToken}}

{
  "questionId": 4,
  "selectedChoices": [],
  "startedAt": "2026-02-11T10:11:00Z",
  "answeredAt": "2026-02-11T10:18:00Z",
  "timeSpentSeconds": 420
}

###############################################
### PART 4: STUDENT - SUBMIT EXAM
###############################################

### 4.1 Submit Exam
# @name submitExam
POST {{baseUrl}}/api/exam-attempts/{{attemptId}}/submit
Authorization: Bearer {{studentToken}}

###############################################
### PART 5: VERIFICATION & HEALTH CHECKS
###############################################

### 5.1 API Health Check
GET {{baseUrl}}/api/health
Accept: application/json

### 5.2 Database Health Check
GET {{baseUrl}}/api/health/db
Accept: application/json

### 5.3 Refresh Student Token
# @name refreshToken
POST {{baseUrl}}/api/auth/refresh
Content-Type: application/json

{
  "refreshToken": "{{loginStudent.response.body.refreshToken}}"
}

###############################################
### PART 6: ERROR HANDLING TESTS
###############################################

### 6.1 Try to join exam again (Should fail - already joined)
POST {{baseUrl}}/api/exams/join
Content-Type: application/json
Authorization: Bearer {{studentToken}}

{
  "examCode": "{{examCode}}"
}

### 6.2 Try to start exam again (Should fail - already in progress)
POST {{baseUrl}}/api/exam-attempts/start
Content-Type: application/json
Authorization: Bearer {{studentToken}}

{
  "examId": {{examId}}
}

### 6.3 Try to access question without authentication (Should fail - 401)
GET {{baseUrl}}/api/exam-attempts/{{attemptId}}/questions/1

### 6.4 Try to join non-existent exam (Should fail - 404)
POST {{baseUrl}}/api/exams/join
Content-Type: application/json
Authorization: Bearer {{studentToken}}

{
  "examCode": "INVALID"
}

### 6.5 Try student to create exam (Should fail - 403 Forbidden)
POST {{baseUrl}}/api/exams
Content-Type: application/json
Authorization: Bearer {{studentToken}}

{
  "title": "Unauthorized Exam",
  "durationMinutes": 60
}

###############################################
### EXECUTION ORDER SUMMARY
###############################################
# 
# 1. INSTRUCTOR WORKFLOW:
#    1.1 → 1.2 → 1.3 → 1.4 → 1.5 → 1.6 → 1.7 → 1.8 → 1.9
#
# 2. STUDENT WORKFLOW:
#    2.1 → 2.2 → 2.3 → 2.4 → 3.1 → 3.2 → 3.3 → 3.4 → 3.5 
#    → 3.6 → 3.7 → 3.8 → 3.9 → 3.10 → 3.11 → 4.1
#
# 3. VERIFICATION:
#    5.1 → 5.2 → 5.3
#
# 4. ERROR TESTS:
#    6.1 → 6.2 → 6.3 → 6.4 → 6.5
#
###############################################

###############################################
### EXPECTED RESULTS
###############################################
#
# Question 1: 10 points (Correct: O(log n))
# Question 2: 15 points (Correct: Array, Linked List, Stack)
# Question 3: 5 points (Correct: False)
# Question 4: 0 points initially (Needs manual grading)
#
# MCQ Score: 30 points
# Total Violations: 2 (1 tab switch + 1 eye away)
# Cheating Status: WARNING (2 violations <= 3)
# Exam Status: SUBMITTED
#
###############################################